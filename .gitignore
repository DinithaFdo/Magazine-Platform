# ============================================
# ROOT LEVEL IGNORE (ALL SERVICES)
# ============================================

# ----------------------------
# Node Modules (ALL services)
# ----------------------------
node_modules/
**/node_modules/

# ----------------------------
# Build Output (ALL services)
# ----------------------------
dist/
build/
**/dist/
**/build/

# ----------------------------
# Logs
# ----------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------
# Environment Variables
# ----------------------------
.env
.env.*
**/.env
**/.env.*

# ----------------------------
# TypeScript
# ----------------------------
*.tsbuildinfo

# ----------------------------
# IDE / Editor files
# ----------------------------
.vscode/
.idea/
*.swp
*.swo

# ----------------------------
# OS files
# ----------------------------
.DS_Store
Thumbs.db

# ----------------------------
# Temporary files
# ----------------------------
tmp/
temp/
**/tmp/
**/temp/

# ----------------------------
# Coverage / Testing
# ----------------------------
coverage/
**/coverage/

# ----------------------------
# Cache
# ----------------------------
.cache/
.eslintcache
**/.cache/

# ----------------------------
# Uploads (Media Service)
# ----------------------------
uploads/
**/uploads/

# ----------------------------
# Misc sensitive files
# ----------------------------
*.pem
*.key
*.crt

# ----------------------------
# Docker (if added later)
# ----------------------------
docker-compose.override.yml
.env.docker

# ----------------------------
# Package manager lock files (optional)
# ----------------------------
# Uncomment if needed
# package-lock.json
# yarn.lock
# pnpm-lock.yaml